# ── LLM Providers (add at least one) ──────────────────────────────────────────
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=

# ── Research & Finance APIs ───────────────────────────────────────────────────
TAVILY_API_KEY=
FINANCIAL_DATASETS_API_KEY=

# ── Local LLM ────────────────────────────────────────────────────────────────
LOCAL_LLM_ENABLED=false
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma4

# ── Thinking Mode (fast | think | complex) ────────────────────────────────────
DEFAULT_THINKING_MODE=think

# ── Desktop Control ───────────────────────────────────────────────────────────
# Set to true to enable full device control (cursor, keyboard, screenshot, apps)
# Install: pip install pyautogui pillow
# macOS: Grant Accessibility permissions in System Preferences > Privacy
DESKTOP_ENABLED=false

# ── Settings ─────────────────────────────────────────────────────────────────
THINKING_ENABLED=true
LLM_TIMEOUT=60
MEMORY_LIMIT=100
