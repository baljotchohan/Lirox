# Lirox API Configuration
# Copy this file to .env and fill in your API keys.
# You only need ONE key to get started — Groq and Gemini have free tiers.

# ─── LLM Providers ─────────────────────────────────────────────────────────────

# Gemini (FREE tier) — https://aistudio.google.com
GEMINI_API_KEY=

# Groq (FREE tier, fast) — https://console.groq.com
GROQ_API_KEY=

# OpenRouter (FREE models available) — https://openrouter.ai
OPENROUTER_API_KEY=

# OpenAI (Paid) — https://platform.openai.com
OPENAI_API_KEY=

# DeepSeek (Very cheap) — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# NVIDIA NIM (FREE tier) — https://build.nvidia.com
NVIDIA_API_KEY=

# ─── Default Settings ──────────────────────────────────────────────────────────

# Default LLM provider (auto = smart routing based on task type)
DEFAULT_MODEL=auto

# Number of conversation turns to keep in memory
MEMORY_LIMIT=20
