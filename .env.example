# ── Lirox v3.0 Configuration ──────────────────────────────────────────────────

# ── LLM Providers (add at least one) ─────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# ── Search ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Desktop Control ───────────────────────────────────────────────────────────
# Set to true to enable full OS control (mouse, keyboard, screenshot, apps)
# Requirements: pip install pyautogui pillow pytesseract
# macOS: grant Accessibility in System Settings → Privacy → Accessibility
DESKTOP_ENABLED=false

# Max steps per desktop task before agent pauses for guidance
DESKTOP_MAX_STEPS=40

# Delay between desktop actions in seconds (0.5–1.0 recommended)
DESKTOP_ACTION_DELAY=0.6

# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
LOCAL_LLM_ENABLED=false
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma4
LOCAL_LLM_PROVIDER=ollama

# ── Core settings ─────────────────────────────────────────────────────────────
THINKING_ENABLED=true
MEMORY_LIMIT=100
LLM_TIMEOUT=60
MAX_AGENT_ITERATIONS=30
