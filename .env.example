# Lirox API Configuration
# Copy this file to .env and fill in your API keys.
# You only need ONE key to get started — Groq and Gemini have free tiers.

# ─── LLM Providers ─────────────────────────────────────────────────────────────

# Gemini (FREE tier) — https://aistudio.google.com
GEMINI_API_KEY=

# Groq (FREE tier, fast) — https://console.groq.com
GROQ_API_KEY=

# OpenRouter (FREE models available) — https://openrouter.ai
OPENROUTER_API_KEY=

# OpenAI (Paid) — https://platform.openai.com
OPENAI_API_KEY=

# DeepSeek (Very cheap) — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# NVIDIA NIM (FREE tier) — https://build.nvidia.com
NVIDIA_API_KEY=

# ─── Additional LLM Providers ────────────────────────────────────────────────

# Anthropic Claude (paid) — best for synthesis and analysis
ANTHROPIC_API_KEY=

# ─── Research Search APIs (optional — improves research quality) ─────────────

# Tavily — best for deep research (free tier: 1000 searches/month)
# Get key: https://app.tavily.com
TAVILY_API_KEY=

# Serper — Google Search API (free tier: 2500 queries/month)
# Get key: https://serper.dev
SERPER_API_KEY=

# Exa — neural search, great for tech/academic topics (free tier available)
# Get key: https://exa.ai
EXA_API_KEY=

# ─── Default Settings ──────────────────────────────────────────────────────────

# Default LLM provider (auto = smart routing based on task type)
DEFAULT_MODEL=auto

# Number of conversation turns to keep in memory
MEMORY_LIMIT=50

# ─── Headless Browser Config (v0.7 — Lightpanda) ──────────────────────────────

# Path to Lightpanda binary (download from github.com/lightpanda-io/browser)
LIGHTPANDA_PATH=./lightpanda

# CDP (Chrome DevTools Protocol) port for browser communication
BROWSER_PORT=9222

# Maximum concurrent browser instances (careful with memory)
BROWSER_MAX_INSTANCES=5

# Default page load timeout in seconds
BROWSER_TIMEOUT=30

# Always headless (agent OS — no GUI)
BROWSER_HEADLESS=true

# Skip loading images for faster extraction (set to true for speed)
BROWSER_DISABLE_IMAGES=false

# Rate limiting per domain (requests per minute)
BROWSER_RATE_LIMIT_PER_DOMAIN=10
