FROM llama3:latest

# Lirox Memory Compressor — Optimized Modelfile
# Generated by scripts/compress_model.py

PARAMETER num_ctx      2048
PARAMETER num_thread   4
PARAMETER num_batch    256
PARAMETER num_predict  512
PARAMETER temperature  0.7
